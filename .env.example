# Selecione o backend de persistência: mysql | mongodb
DB_BACKEND=mysql

# MySQL (usado quando DB_BACKEND=mysql)
# Dica: em Docker Compose use "mysql"; fora do Docker use "localhost".
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=products
MYSQL_PASSWORD=products
MYSQL_DATABASE=products
# Alternativa (opcional): MYSQL_URL=mysql+pymysql://user:pass@host:3306/db?charset=utf8mb4

# MongoDB (usado quando DB_BACKEND=mongodb)
# Dica: em Docker Compose use "mongo"; fora do Docker use "localhost".
MONGO_URI=mongodb://mongo:27017
MONGO_DATABASE=products

# Gunicorn (produção)
LOG_LEVEL=info
# WEB_CONCURRENCY=2
# WEB_TIMEOUT=60
